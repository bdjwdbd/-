{
  "name": "humanoid-agent",
  "version": "4.9.6",
  "description": "元灵系统 - 多Agent协作框架，集成 Harness Engineering",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:wasm": "npx asc assembly/index.ts -o build/release.wasm --optimize --simd",
    "build:wasm:debug": "npx asc assembly/index.ts -o build/debug.wasm --debug",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:harness": "npx ts-node src/harness/__tests__/harness.test.ts && npx ts-node src/harness/__tests__/p1.test.ts && npx ts-node src/harness/__tests__/p2.test.ts",
    "test:integration": "npx ts-node src/integration/__tests__/deep-integration.test.ts && npx ts-node src/integration/__tests__/validation.test.ts",
    "test:main": "npx ts-node src/__tests__/main-flow.test.ts",
    "test:all": "npm run test && npm run test:harness && npm run test:integration && npm run test:main",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "benchmark": "ts-node src/benchmarks/index.ts",
    "benchmark:main": "ts-node src/benchmarks/main-flow.benchmark.ts",
    "docs": "typedoc --out docs/api src/index.ts",
    "docs:full": "typedoc --out docs/api src/index.ts --readme docs/API.md",
    "check:exports": "node scripts/check-exports.js",
    "check:integration": "node scripts/check-integration.js",
    "check:dependencies": "node scripts/check-dependencies.js",
    "check:all": "npm run check:exports && npm run check:integration && npm run typecheck && npm run version:check",
    "integrate": "node scripts/auto-integrate.js",
    "discover": "npx ts-node scripts/auto-discover.ts",
    "version:check": "node scripts/check-version.js",
    "release": "npm run check:all && npm run test:all && npm run build",
    "example:basic": "ts-node examples/basic-usage.ts",
    "example:executor": "ts-node examples/external-executor.ts",
    "example:harness": "ts-node examples/harness-demo.ts"
  },
  "keywords": [
    "agent",
    "llm",
    "memory",
    "harness",
    "sandbox",
    "tracing",
    "metrics",
    "simd",
    "vector-search",
    "gpu",
    "wasm"
  ],
  "author": "YuanLing Team",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/benchmark": "^2.1.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "benchmark": "^2.1.4",
    "jest": "^29.7.0",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.2.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@types/sqlite3": "^5.1.0",
    "better-sqlite3": "^12.9.0",
    "koffi": "^2.16.0",
    "lru-cache": "^10.4.3",
    "pino": "^8.21.0",
    "pino-pretty": "^10.3.1",
    "sqlite3": "^6.0.1"
  },
  "optionalDependencies": {
    "gpu.js": "^2.16.0",
    "ml-matrix": "^6.12.1"
  },
  "directories": {
    "doc": "docs",
    "lib": "dist",
    "test": "src/__tests__"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bdjwbdb/humanoid-agent.git"
  },
  "bugs": {
    "url": "https://github.com/bdjwbdb/humanoid-agent/issues"
  },
  "homepage": "https://github.com/bdjwbdb/humanoid-agent#readme"
}
